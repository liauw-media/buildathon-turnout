# Copy this file to .env.local and fill in with your Supabase project credentials.
# Get them from: https://supabase.com/dashboard/project/_/settings/api
# ⚠️  Keep real credentials only in .env.local (gitignored). Never commit them here.

# ─── Supabase (required for magic-link auth + persistent commits) ───
NEXT_PUBLIC_SUPABASE_URL=
# New-style publishable key (preferred). Legacy name NEXT_PUBLIC_SUPABASE_ANON_KEY also accepted.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — used by server actions & seed scripts. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── App config ───
# Used to build magic-link redirect URLs. Set to your deploy URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Behaviour ───
# Leave all Supabase vars blank for local development:
# the app will fall back to the JSON file store (data/commits.json) and skip magic-link.
# Set all three Supabase vars and it automatically switches to Supabase + magic-link auth.
